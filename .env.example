# SniperX — environment variables
# Copy to .env and fill in your values.

# ── Telegram (required for bot control) ──────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Solana ───────────────────────────────────────────────────────
# Defaults to public mainnet RPC if unset.
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
WALLET_PRIVATE_KEY_PATH=./phantom_key.json
# Optional base58 secret (prefer file path for local use):
# WALLET_PRIVATE_KEY_BASE58=

# ── Optional services ────────────────────────────────────────────
OPENAI_API_KEY=
DATABASE_URL=

# ── Trading ──────────────────────────────────────────────────────
ENABLE_LIVE_TRADING=false
LIVE_TRADING_CONFIRMATION=

# ── Server ───────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
