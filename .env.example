# SniperX Environment Variables
# Copy this file to .env and fill in your actual values

# Solana Configuration
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_NETWORK=mainnet-beta
WALLET_MNEMONIC=your-wallet-mnemonic-phrase-here

# API Keys
OPENAI_API_KEY=sk-xxxxx
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id
COINGECKO_API_KEY=your-coingecko-api-key

# Google Sheets Configuration
GOOGLE_SHEETS_ID=1kdlXUEErNutCnqu7BuLxNBAmNftM2czKkMOBlHz5vaw
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com

# Twilio Configuration (for SMS alerts)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Stripe Configuration (for payments)
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# Security Configuration
JWT_SECRET=your-super-secret-jwt-key
API_KEY=your-api-key-for-authentication
SESSION_SECRET=your-session-secret

# Trading Configuration
ENABLE_LIVE_TRADING=false
MAX_POSITION_SIZE=1000
STOP_LOSS_PERCENTAGE=2
TAKE_PROFIT_PERCENTAGE=8
SLIPPAGE_TOLERANCE=0.5

# Database Configuration (already provided by Replit)
# DATABASE_URL is automatically provided

# Server Configuration
PORT=5000
NODE_ENV=production