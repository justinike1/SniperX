
NODE_ENV=development
PORT=5000
JWT_SECRET=replace-with-32+chars-secret

SOLANA_NETWORK=mainnet-beta
SOLANA_RPC_URLS=https://api.mainnet-beta.solana.com
WALLET_PUBLIC_KEY=your-public-key
WALLET_PRIVATE_KEY_PATH=/abs/path/phantom_key.json

# execution toggles (KEEP DRY RUN TRUE until proven)
DRY_RUN=true
ENABLE_SPOT_LIVE=false
ENABLE_PERP_LIVE=false

# risk
MAX_SPEND_PER_TRADE=0.25
MAX_DAILY_SPEND=1.0
MIN_WALLET_BALANCE=0.05
MAX_VOLATILITY=25
MAX_SLIPPAGE=5
RISK_OFF_DD_PCT=10
BLOCK_DD_PCT=25

# ops
METRICS_ENABLED=true

# alerts
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# advanced exec
SX_MAX_RETRIES=3
SX_RETRY_BACKOFF_MS=500
PRIORITY_FEE_LAMPORTS=5000
JUP_DIRECT_ONLY=false
DRIFT_PERP_SYMBOL=SOL-PERP
PERP_MAX_LEVERAGE=3
